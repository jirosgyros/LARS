# Copy to .env and fill in real values. .env is gitignored.

# LLM backend selection.
# Default (cli) shells out to the `claude` CLI -- subscription-billed via
# Claude Code, no per-token charges. Requires Claude Code installed.
# Set to 'api' to use Anthropic's per-token API instead -- requires the
# ANTHROPIC_API_KEY below.
LLM_BACKEND=cli

# Only needed if LLM_BACKEND=api. Get one at https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-your-key-here
